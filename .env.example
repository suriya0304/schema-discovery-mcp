# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Postgres superuser (used only at container init, and by nothing else) ---
POSTGRES_USER=app_admin
POSTGRES_PASSWORD=change_me_admin_password
POSTGRES_DB=delivery_tracker

# --- Read-only role the MCP server connects as (see db/init/03_readonly_role.sh) ---
MCP_READONLY_PASSWORD=change_me_reader_password

# --- LLM provider (used only by the agent-api container) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
